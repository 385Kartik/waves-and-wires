# Copy to .env — NEVER commit .env to git

# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Your live domain (optional on localhost — used for email redirects)
# VITE_SITE_URL=https://wavesandwires.com

# Razorpay — Get from: razorpay.com → Settings → API Keys
# Use test key (rzp_test_...) on localhost, live key (rzp_live_...) for production
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Email (Netlify Function / Nodemailer)
# Netlify Dashboard mein jaake: Site Settings → Environment Variables mein add karo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_NAME=Waves & Wires

RAZORPAY_KEY_ID      = rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET  = your_secret_key